# ================================
# PRODUCTION ENVIRONMENT VARIABLES
# ================================
# Copy this to .env and fill in your values

# Django Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-generate-a-new-one-for-production

# Database (PostgreSQL from Digital Ocean)
DATABASE_URL=postgresql://user:password@host:port/database

# Allowed Hosts (your Digital Ocean domain/IP)
ALLOWED_HOSTS=your-api-domain.com,www.your-api-domain.com

# CORS (your Vercel frontend URL)
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-custom-domain.com

# Frontend URL (for email links)
FRONTEND_URL=https://your-frontend.vercel.app

# Email Settings (Gmail SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
